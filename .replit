modules = ["nodejs-20"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd wwew && PORT=8080 DASHBOARD_PORT=5000 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd wwew && PORT=5000 API_SERVER_PORT=8080 pnpm --filter @workspace/dashboard run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 8080

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd wwew && PORT=8080 DASHBOARD_PORT=5000 node artifacts/api-server/dist/index.mjs & PORT=5000 API_SERVER_PORT=8080 pnpm --filter @workspace/dashboard run dev --host 0.0.0.0"]
build = ["bash", "-c", "cd wwew && pnpm install --frozen-lockfile && pnpm --filter @workspace/api-server run build"]
